#!/bin/sh

#set -euo pipefail
set -eu

temp=""

for zone in /sys/class/thermal/thermal_zone*; do
  if [ -r "$zone/temp" ]; then
    read -r raw_temp < "$zone/temp" || continue
    if [ "${raw_temp:-0}" -gt 0 ] 2>/dev/null; then
      temp=$((raw_temp / 1000))
      break
    fi
  fi
done

#if [ -z "${temp:-}" ]; then
