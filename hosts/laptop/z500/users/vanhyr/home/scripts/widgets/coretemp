#!/bin/sh

set -euo pipefail

for zone in /sys/class/thermal/thermal_zone*; do
  if [ -r "$zone/temp" ]; then
    if read -r raw_temp < "$zone/temp"; then
      if (( raw_temp > 0 )); then
        temp=$((raw_temp / 1000))
        break
      fi
    fi
  fi
done

if [ -z "${temp:-}" ]; then
  echo "ï‹“ N/A"
  exit 1
fi

