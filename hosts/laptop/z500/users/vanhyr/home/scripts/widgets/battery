#!/bin/sh

#set -euo pipefail
set -eu

bat_path="/sys/class/power_supply/BAT1"

[ -d "$bat_path" ] || exit 0

read -r capacity < "$bat_path/capacity" 2>/dev/null || exit 0
read -r status < "$bat_path/status" 2>/dev/null || exit 0

rounded=$(( ((capacity + 5) / 10) * 10 ))

case "$status" in
  "Charging")
    icon="σΑ²³"
  ;;
  "Discharging"|"Not charging")
    case "$rounded" in
      0)   icon="σΑ²é" ;;
      10)  icon="σΑ¹Κ" ;;
      20)  icon="σΑ¹Μ" ;;
      30)  icon="σΑ¹Φ" ;;
      40)  icon="σΑ¹Ϋ" ;;
      50)  icon="σΑ¹Ψ" ;;
      60)  icon="σΑ¹Ω" ;;
      70)  icon="σΑ²Ä" ;;
      80)  icon="σΑ²¹" ;;
      90)  icon="σΑ²²" ;;
      100) icon="σΑ¹Ι" ;;
    esac
  ;;
  "Full")
    icon="σΑ¹Ι"
  ;;
  *)
    icon="σΑ²ë"
  ;;
esac

printf '%s %d%%\n' "$icon" "$capacity"
