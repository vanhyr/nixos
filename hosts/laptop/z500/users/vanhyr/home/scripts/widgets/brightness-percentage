#!/bin/sh

#set -euo pipefail
set -eu

backlight_path="/sys/class/backlight/ideapad"

[ -d "$backlight_path" ] || { printf '箚깯 N/A\n'; exit 0; }

read -r curr_brightness < "$backlight_path/brightness"
read -r max_brightness < "$backlight_path/max_brightness"

[ "$max_brightness" -gt 0 ] || { printf '箚깯 N/A\n'; exit 0; }

percent=$(( (100 * curr_brightness + max_brightness / 2) / max_brightness ))

if [ "$percent" -le 0 ]; then
  icon="箚깯"
elif [ "$percent" -lt 30 ]; then
  icon="箚깱"
elif [ "$percent" -lt 70 ]; then
  icon="箚깮"
else
  icon="箚깲"
fi

printf '%s %d%%\n' "$icon" "$percent"
